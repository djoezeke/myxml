{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "build",
      "installDir": "${sourceDir}/build/install",
      "description": "Default build with static library, examples, and tests enabled",
      "cacheVariables": {
        "CMAKE_C_EXTENSIONS": "OFF",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MYXML_BUILD_TESTS": "ON",
        "MYXML_BUILD_DEBUG": "OFF",
        "MYXML_BUILD_SHARED": "ON",
        "MYXML_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "develop",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/develop",
      "installDir": "${sourceDir}/build/install",
      "description": "Debug build for development with examples and tests enabled",
      "cacheVariables": {
        "CMAKE_C_EXTENSIONS": "OFF",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MYXML_BUILD_TESTS": "ON",
        "MYXML_BUILD_DEBUG": "ON",
        "MYXML_BUILD_SHARED": "ON",
        "MYXML_BUILD_EXAMPLES": "ON"
      }
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "develop",
      "configurePreset": "develop",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
